# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=value_stock_picker

# ─── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=changeme-use-a-long-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── SEC EDGAR ───────────────────────────────────────────────────────────────
# Required per SEC fair-access policy. Format: "AppName contact@email.com"
SEC_USER_AGENT=ValueStockPicker your@email.com

# ─── External API Keys (all optional — app works without them) ───────────────

# Alpha Vantage — free tier: 25 premium req/day, 500 standard req/day
# Register at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# FRED (St. Louis Federal Reserve) — higher rate limits with a key
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# BLS (Bureau of Labor Statistics) — unlocks v2 API (higher limits)
# Register at: https://www.bls.gov/developers/home.htm
BLS_API_KEY=

# ─── Cache TTLs (seconds) ────────────────────────────────────────────────────
PRICE_CACHE_TTL=60            # 1 min  — real-time prices
FUNDAMENTALS_CACHE_TTL=3600   # 1 hr   — company fundamentals
FILINGS_CACHE_TTL=86400       # 24 hrs — SEC filings + macro data
