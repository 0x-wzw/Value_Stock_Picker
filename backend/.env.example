# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/value_stock_picker

# Auth (use a long random string in production)
SECRET_KEY=changeme-use-a-long-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SEC EDGAR — must identify your app per SEC policy
# Format: "AppName contact@email.com"
SEC_USER_AGENT=ValueStockPicker your@email.com

# Optional: Alpha Vantage API key (free tier at alphavantage.co)
ALPHA_VANTAGE_API_KEY=

# Cache TTLs (seconds)
PRICE_CACHE_TTL=60
FUNDAMENTALS_CACHE_TTL=3600
FILINGS_CACHE_TTL=86400
